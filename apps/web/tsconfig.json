{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Workspace Paths */
    "baseUrl": ".",
    "paths": {
      "@mahathi/types": ["../../packages/types/src/index.ts"],
      "@mahathi/validation": ["../../packages/validation/src/index.ts"],
      "@mahathi/utils": ["../../packages/utils/src/index.ts"],
      "@mahathi/ui": ["../../packages/ui/src/index.tsx"]
    }
  },
  "include": ["src"]
}
